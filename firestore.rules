rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── GLOBAL RESOURCES (read by everyone, write by admin only) ───
    match /resources/{docId} {
      allow read: if true;
      allow write: if request.auth != null 
                   && request.auth.token.email == 'alaidan25@gmail.com';
    }

    // ─── USER FAVORITES (private per user) ──────────────────────────
    match /users/{userId}/favorites/{item} {
      allow read, write: if request.auth != null 
                         && request.auth.uid == userId;
    }

    // ─── CATEGORIES (Temporary Public Access for Fix) ────────────────
    match /categories/{docId} {
      allow read, write: if true;
    }

    // ─── BUG REPORTS (Security Temporary Flush) ─────────────────
    match /bug_reports/{docId} {
      allow read, write, create: if true;
    }

  }
}
