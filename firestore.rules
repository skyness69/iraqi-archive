rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── USER DATA: Only users can touch their own favorites ───────────
    match /users/{userId}/favorites/{item} {
      allow read, write: if isVerified() && request.auth.uid == userId;
    }

    // ─── ARCHIVE RESOURCES: Admin Only ──────────────────────────────────
    match /resources/{docId} {
      allow read: if true;
      
      // Allow deletion for admin without field checks (since data is null)
      allow delete: if isAdmin();
      
      // Allow creation/updates with validation
      allow create, update: if isAdmin() && (
        // Special case for the metadata doc
        docId == '--categories-metadata--' || (
          request.resource.data.title.size() < 100 &&
          request.resource.data.desc.size() < 1000
        )
      );
    }

    // ─── PREVIOUS CATEGORIES COLLECTION (Legacy Support) ──────────────
    match /categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── BUG REPORTS: Authenticated Users Only ───────────────────────
    match /bug_reports/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.user.size() < 100
                    && request.resource.data.subject.size() < 200
                    && request.resource.data.message.size() < 2000;
                    
      allow read, update, delete: if isAdmin();
    }

    // Helper: Check if active user is the vault master
    function isAdmin() {
      return request.auth != null && request.auth.token.email.matches('(?i)alaidan25@gmail\\.com');
    }

    // Helper: Check if identity is cryptographically verified
    function isVerified() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

  }
}
